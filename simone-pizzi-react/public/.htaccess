
# ================================================================
# .htaccess SEMPLIFICATO - SimonePizziWebSite
# Compatibilità massima con hosting condivisi
# ================================================================

# ================================================================
# ESCLUDI LA LANDING PAGE /respiro-trattenuto DAL FALLBACK SPA
# Serve direttamente i file statici della landing page
RewriteEngine On
RewriteCond %{REQUEST_URI} ^/respiro-trattenuto/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^respiro-trattenuto/(.*)$ /respiro-trattenuto/$1 [L]

# HTTPS REDIRECT
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ================================================================
# SECURITY HEADERS BASILARI

# ================================================================
# .htaccess SEMPLIFICATO - SimonePizziWebSite (versione compatibile)
# ================================================================

# 1. HTTPS REDIRECT
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# 2. ESCLUDI LA LANDING PAGE /respiro-trattenuto DAL FALLBACK SPA
RewriteCond %{REQUEST_URI} ^/respiro-trattenuto/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^respiro-trattenuto/(.*)$ /respiro-trattenuto/$1 [L]

# 3. SPA FALLBACK SOLO PER IL SITO PRINCIPALE
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^.*$ /index.html [L]

# 4. SECURITY HEADERS BASILARI
Header always set X-Content-Type-Options "nosniff"
Header always set X-Frame-Options "DENY"
Header always set X-XSS-Protection "1; mode=block"
Header always set Referrer-Policy "strict-origin-when-cross-origin"
Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' fonts.googleapis.com https://cdnjs.cloudflare.com; font-src 'self' fonts.gstatic.com https://cdnjs.cloudflare.com; img-src 'self' data:; connect-src 'self' https://formspree.io"
Header unset Server
Header unset X-Powered-By

# 5. COMPRESSIONE GZIP BASICA
AddOutputFilterByType DEFLATE text/html text/css text/javascript application/javascript application/x-javascript text/xml application/xml

# 6. BROWSER CACHING SEMPLIFICATO
ExpiresActive on
ExpiresByType text/css "access plus 1 year"
ExpiresByType application/javascript "access plus 1 year"
ExpiresByType text/javascript "access plus 1 year"
ExpiresByType image/png "access plus 1 year"
ExpiresByType image/jpg "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/gif "access plus 1 year"
ExpiresByType image/svg+xml "access plus 1 year"

# 7. FILE PROTECTION ESSENZIALE
<Files ".htaccess">
    Order Allow,Deny
    Deny from all
</Files>
<FilesMatch "\.(log|md|json|txt|py|gitignore|env)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# 8. MIME TYPES ESSENZIALI
<Files "sitemap.xml">
    Header set Content-Type "application/xml; charset=utf-8"
</Files>
<Files "robots.txt">
    Header set Content-Type "text/plain; charset=utf-8"
</Files>

# 9. DEVELOPMENT ENVIRONMENT RESTRICTIONS
<FilesMatch "\.(env|git|vscode|idea)">
    Order Allow,Deny
    Deny from all
</FilesMatch>
# <Directory "docs">
#     Order Allow,Deny
#     Deny from all
# </Directory>

# ================================================================
# END CONFIGURATION
# ================================================================