<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 32 32">
  <defs>
    <radialGradient id="breathGlow" cx="50%" cy="50%" r="50%">
      <stop offset="0%" style="stop-color:#00ff41;stop-opacity:1" />
      <stop offset="70%" style="stop-color:#00cc33;stop-opacity:0.8" />
      <stop offset="100%" style="stop-color:#008822;stop-opacity:0.3" />
    </radialGradient>
    <filter id="glow">
      <feGaussianBlur stdDeviation="2" result="coloredBlur"/>
      <feMerge> 
        <feMergeNode in="coloredBlur"/>
        <feMergeNode in="SourceGraphic"/> 
      </feMerge>
    </filter>
  </defs>
  
  <!-- Background circle -->
  <circle cx="16" cy="16" r="15" fill="#000000" stroke="#00ff41" stroke-width="1"/>
  
  <!-- Central breathing symbol -->
  <circle cx="16" cy="16" r="8" fill="url(#breathGlow)" filter="url(#glow)" opacity="0.9"/>
  
  <!-- Inner core -->
  <circle cx="16" cy="16" r="3" fill="#00ff41" filter="url(#glow)"/>
</svg>